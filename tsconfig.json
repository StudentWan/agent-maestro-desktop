{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@copilot/*": ["./src/copilot/*"],
      "@converter/*": ["./src/converter/*"],
      "@proxy/*": ["./src/proxy/*"],
      "@store/*": ["./src/store/*"],
      "@codespace/*": ["./src/codespace/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
