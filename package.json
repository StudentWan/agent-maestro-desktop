    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.20",
    "electron": "^34.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
